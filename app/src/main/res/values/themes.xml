<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.RealTime" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">?attr/clockBackgroundColor</item>

        <item name="clockTextColor">@color/clock_text</item>
        <item name="clockDateColor">@color/clock_date</item>
        <item name="clockAccentColor">?attr/colorPrimary</item>
        <item name="clockBackgroundColor">@color/clock_background</item>
        <item name="clockCardBackgroundColor">@color/clock_card</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.RealTime.AlertDialog</item>
    </style>

    <style name="ThemeOverlay.RealTime.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog"/>
</resources>
